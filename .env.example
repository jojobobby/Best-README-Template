# =============================================================================
# ApplyBot Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- General ---
NODE_ENV=development                    # development | production | test
LOG_LEVEL=info                          # debug | info | warn | error
LOG_TO_FILE=false                       # Write logs to file in addition to console

# --- Database (Postgres) ---
DATABASE_URL=postgresql://applybot:applybot@localhost:5432/applybot?schema=public

# --- Redis ---
REDIS_URL=redis://:applybot@localhost:6379

# --- API Server ---
PORT=3000                               # Express server port
API_KEY=change-me-to-a-32-char-min-key  # API key for protected endpoints (min 32 chars)

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Your Twilio Account SID
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx      # Your Twilio Auth Token (32 chars)
TWILIO_FROM_NUMBER=+15551234567                         # Your Twilio phone number (E.164)
OWNER_PHONE=+15559876543                                # Your personal phone number (E.164)

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx   # Claude API key for form detection and cover letters

# --- Identity Encryption ---
IDENTITY_KEY=generate-with-openssl-rand-hex-32          # 256-bit hex key for AES-256-GCM encryption
IDENTITY_PATH=/identity/profile.enc                     # Path to encrypted identity profile
RESUME_PATH=/identity/resume.pdf                        # Path to resume PDF file
SCREENSHOT_DIR=/identity/screenshots                    # Directory for application screenshots

# --- Job Scraper: Adzuna ---
ADZUNA_APP_ID=your-adzuna-app-id        # Adzuna API application ID
ADZUNA_APP_KEY=your-adzuna-app-key      # Adzuna API application key

# --- Job Scraper: Company Boards ---
GREENHOUSE_COMPANY_SLUGS=stripe,figma,notion             # Comma-separated Greenhouse company slugs
LEVER_COMPANY_SLUGS=netflix,cloudflare                   # Comma-separated Lever company slugs

# --- Job Search Filters ---
SEARCH_KEYWORDS=software engineer,fullstack,backend,frontend  # Comma-separated job title keywords
SEARCH_LOCATION=United States                                  # Location filter for Adzuna
EXCLUDE_KEYWORDS=senior,staff,principal,director,vp,intern     # Keywords to exclude from results

# --- Scraper Schedule ---
SCRAPE_INTERVAL_MINUTES=30              # How often to run scrapers (minutes)
SCRAPE_ON_START=true                    # Run all scrapers immediately on startup
DAILY_SUMMARY_CRON=0 18 * * *          # Cron expression for daily summary SMS (6pm)

# --- Playwright / Apply Agent ---
HEADLESS=true                           # Run browser in headless mode
BROWSER_POOL_SIZE=2                     # Max concurrent browser instances
MAX_RETRIES=3                           # Max retry attempts for failed applications
PLAYWRIGHT_CHROMIUM_ARGS=--no-sandbox --disable-setuid-sandbox  # Chrome launch args

# --- Optional: CAPTCHA Solving ---
TWOCAPTCHA_API_KEY=                     # 2Captcha API key (leave empty to skip CAPTCHA jobs)

# --- Optional: Workday Login ---
WORKDAY_EMAIL=                          # Workday account email (leave empty to skip Workday)
WORKDAY_PASSWORD=                       # Workday account password

# --- Bull Board (Admin Dashboard) ---
BULL_BOARD_USER=admin                   # Bull Board basic auth username
BULL_BOARD_PASS=change-me               # Bull Board basic auth password

# --- Metrics ---
METRICS_TOKEN=                          # Bearer token for /metrics endpoint (optional)
