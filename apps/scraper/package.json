{
  "name": "@applybot/scraper",
  "version": "1.0.0",
  "private": true,
  "description": "ApplyBot job scraper service for Adzuna, Greenhouse, and Lever",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@applybot/db": "workspace:*",
    "@applybot/shared": "workspace:*",
    "bull": "^4.12.0",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0"
  }
}
